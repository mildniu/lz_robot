# 历史兼容示例，仅供参考。
# 当前程序运行时主要读取 settings/app_config.json 与其他 settings/*.json。
# 如需查看完整运行配置，请以 README.md 和 GUI 设置页为准。

IMAP_HOST=imap.example.com
IMAP_PORT=993
EMAIL_USERNAME=your_mail@example.com
EMAIL_PASSWORD=your_auth_code_here
IMAP_MAILBOX=INBOX
POLL_INTERVAL_SECONDS=600
DOWNLOAD_DIR=./downloads
STATE_FILE=./state/mail_state.json
WEBHOOK_SEND_URL=https://example.com/im-external/v1/webhook/send?key=your_key_here
MAX_ATTACHMENT_SIZE_MB=30
SCRIPT_TIMEOUT_SECONDS=300